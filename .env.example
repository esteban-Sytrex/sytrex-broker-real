# Form submission endpoint (POST). Request body: { fullName, email, phone, company, jobTitle }
VITE_FORM_SUBMIT_URL=

# Slack Incoming Webhook URL (server-side only, no VITE_ prefix – never exposed to the browser).
# In dev, the Vite plugin (vite.config.js) forwards /api/slack-demo to this URL.
# On Vercel, set this in project Settings → Environment Variables.
SLACK_WEBHOOK_URL=

# Optional: override the Loom video embed URL (defaults to Sytrex demo video)
# VITE_LOOM_EMBED_URL=https://www.loom.com/embed/658e29e14c3f489c84525e7e20a379a9
